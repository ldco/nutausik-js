{
  "name": "@nocowboy/nutausik",
  "version": "0.2.0",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "nutausik": "dist/index.js",
    "tausik": "dist/index.js"
  },
  "files": [
    "dist/",
    "stacks/",
    "skills/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js --serve",
    "start:cli": "node dist/index.js",
    "start:mcp": "node dist/index.js --serve",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit/",
    "test:integration": "vitest run tests/integration/",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.15.0",
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^2.2.0",
    "better-sqlite3": "^12.11.1",
    "commander": "^12.0.0",
    "execa": "^9.0.0",
    "jsdom": "^29.1.1",
    "lru-cache": "^11.0.0",
    "pino": "^9.0.0",
    "sql.js": "^1.14.1"
  },
  "optionalDependencies": {
    "@mozilla/readability": "^0.5.0",
    "cheerio": "^1.0.0",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^22.0.0",
    "@types/turndown": "^5.0.6",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true
  }
}
